FROM php:apache

COPY entrypoint.sh /usr/local/bin/project-entrypoint
RUN chmod +x /usr/local/bin/project-entrypoint

# Composer (for installing PHP libraries into the mounted project folder)
COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

# Realment només necessitem això per mysql 
#La gent de docker i php han preparat uns scripts que ens faciliten la feina
# i ens permeten instal·lar extensions de php de manera senzilla
RUN docker-php-ext-install pdo_mysql mysqli

# MongoDB extension (required by mongodb/mongodb)
RUN apt-get update \
    && apt-get install -y --no-install-recommends $PHPIZE_DEPS \
    && pecl install mongodb \
    && docker-php-ext-enable mongodb \
    && apt-get purge -y --auto-remove $PHPIZE_DEPS \
    && rm -rf /var/lib/apt/lists/*

# Enable Apache mod_rewrite
RUN a2enmod rewrite

# Exemple de com instal·lar altres paquets a la imatge
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        unzip \
        zip \
    && rm -rf /var/lib/apt/lists/*

ENTRYPOINT ["/usr/local/bin/project-entrypoint"]
CMD ["apache2-foreground"]


