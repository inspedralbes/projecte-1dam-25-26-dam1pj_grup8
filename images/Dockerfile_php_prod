FROM php:apache

# Composer
COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

COPY images/entrypoint.sh /usr/local/bin/project-entrypoint
RUN chmod +x /usr/local/bin/project-entrypoint

RUN docker-php-ext-install pdo_mysql mysqli
RUN a2enmod rewrite

# MongoDB extension (required by mongodb/mongodb)
RUN apt-get update \
    && apt-get install -y --no-install-recommends $PHPIZE_DEPS \
    && pecl install mongodb \
    && docker-php-ext-enable mongodb \
    && apt-get purge -y --auto-remove $PHPIZE_DEPS \
    && rm -rf /var/lib/apt/lists/*
RUN apt-get update && apt-get install -y \
    unzip \
    zip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /var/www/html

COPY php/ /var/www/html/

# Install PHP dependencies into the image so production works without extra steps.
RUN composer install --no-interaction --prefer-dist --optimize-autoloader

ENTRYPOINT ["/usr/local/bin/project-entrypoint"]
CMD ["apache2-foreground"]
