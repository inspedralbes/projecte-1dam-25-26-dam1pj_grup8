# Copy this file to ".env" and fill in the values.
# Docker Compose will load .env automatically.

# Development (local docker-compose MongoDB)
# Include the database name in the URI path.
MONGODB_URI=mongodb://mongo:27017/incidencies

# Production (Atlas) example:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/incidencies?retryWrites=true&w=majority&appName=<appName>

# If your Atlas URI does NOT include the database in the path (no "/incidencies"),
# you can provide it separately:
# MONGODB_DB=incidencies

# Optional sample variable already referenced by docker-compose.yaml
VAR2=valor_exemple
